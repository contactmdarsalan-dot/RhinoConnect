{
  "name": "rhinoconnect",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @rhinoconnect/web",
    "build": "npm run build --workspace @rhinoconnect/web",
    "start": "npm run start --workspace @rhinoconnect/web",
    "lint": "npm run lint --workspace @rhinoconnect/web",
    "web:dev": "npm run dev --workspace @rhinoconnect/web",
    "web:build": "npm run build --workspace @rhinoconnect/web",
    "web:lint": "npm run lint --workspace @rhinoconnect/web",
    "api:check": "cd services/api && python manage.py check",
    "api:migrate": "cd services/api && python manage.py migrate",
    "api:dev": "cd services/api && python manage.py runserver 8000"
  }
}
